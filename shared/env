# Shared environment variables
# This file contains environment variables that work across bash, zsh, and fish
# Source this file from your shell-specific configuration using bass for fish compatibility

# Set CODE_HOME if not already set
export CODE_HOME="${CODE_HOME:-$HOME/Code}"

# Add bin directory to PATH
export PATH="$HOME/.dotfiles/bin:$PATH"

# User-local binaries (XDG ~/.local/bin: pip --user, cargo, etc.)
if [ -d "$HOME/.local/bin" ]; then
  PATH="$HOME/.local/bin:$PATH"
fi

