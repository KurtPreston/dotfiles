#!/usr/bin/env bash
#
# wt - worktree-centric session manager
#
# One bare "base" repo per project, one git worktree per branch in a
# predictable folder, one tmux session per project (a window per worktree,
# a pane per tool), and a deterministic color theme shared between tmux and
# Cursor/VSCode.
#
# git is the source of truth: branch -> folder mapping comes straight from
# `git worktree list`, so there is no separate state file to drift.
#
# Shell integration: a `wt` shell function (see shared/functions and
# fish/functions.fish) sets $WT_CD_FILE to a temp file before calling this
# script. When a command should move the caller's shell, we write the target
# directory there; the function reads it and performs the cd. Everything else
# (fzf, prompts, tmux attach) runs here with the inherited terminal.

set -uo pipefail

CODE_HOME="${CODE_HOME:-$HOME/Code}"

# Comma-separated list of name=command pairs; each becomes a tmux pane split
# within the worktree's window. An empty command means a plain shell.
# Override in your shell config.
WT_TMUX_LAYOUT="${WT_TMUX_LAYOUT:-shell=,claude=claude}"

# Colon-separated list of untracked files copied from the default-branch
# worktree into each new worktree.
WT_COPY="${WT_COPY:-.env}"

# Curated, visually distinct, terminal-friendly palette.
WT_PALETTE=(
  "#3b82f6" "#ef4444" "#22c55e" "#eab308"
  "#a855f7" "#ec4899" "#14b8a6" "#f97316"
  "#6366f1" "#84cc16" "#06b6d4" "#f43f5e"
)

# ----------------------------------------------------------------------------
# Output helpers
# ----------------------------------------------------------------------------
_c_reset=$'\033[0m'; _c_bold=$'\033[1m'; _c_dim=$'\033[2m'
_c_red=$'\033[0;31m'; _c_green=$'\033[0;32m'; _c_yellow=$'\033[1;33m'

log()  { printf '%s\n' "$*" >&2; }
info() { printf '%b\n' "${_c_green}$*${_c_reset}" >&2; }
warn() { printf '%b\n' "${_c_yellow}$*${_c_reset}" >&2; }
die()  { printf '%b\n' "${_c_red}error:${_c_reset} $*" >&2; exit 1; }

# Record the directory the calling shell should cd into.
emit_cd() {
  [ -n "${WT_CD_FILE:-}" ] && printf '%s' "$1" > "$WT_CD_FILE"
}

# ----------------------------------------------------------------------------
# Color helpers
# ----------------------------------------------------------------------------
color_for_branch() {
  local sum idx
  sum=$(printf '%s' "$1" | cksum | awk '{print $1}')
  idx=$(( sum % ${#WT_PALETTE[@]} ))
  printf '%s' "${WT_PALETTE[$idx]}"
}

fg_for_hex() {
  local hex=${1#\#} r g b lum
  r=$((16#${hex:0:2})); g=$((16#${hex:2:2})); b=$((16#${hex:4:2}))
  lum=$(( (r * 299 + g * 587 + b * 114) / 1000 ))
  if [ "$lum" -gt 140 ]; then printf '#000000'; else printf '#ffffff'; fi
}

swatch() {
  local hex=${1#\#} r g b
  r=$((16#${hex:0:2})); g=$((16#${hex:2:2})); b=$((16#${hex:4:2}))
  printf '\033[48;2;%d;%d;%dm   \033[0m' "$r" "$g" "$b"
}

# ----------------------------------------------------------------------------
# Project / worktree resolution (git is the database)
# ----------------------------------------------------------------------------
BASE=""          # path to the bare repo (.base)
PROJECT_DIR=""   # parent dir holding .base and the worktrees

resolve_base() {
  # Prefer the wt project marker: walk up to a directory containing .base.
  # This works from the project root, from inside any worktree, and from any
  # subdirectory of either (git rev-parse only works inside a worktree).
  local dir="$PWD"
  while [ -n "$dir" ] && [ "$dir" != "/" ]; do
    if [ -d "$dir/.base" ]; then
      BASE="$dir/.base"
      PROJECT_DIR="$dir"
      return 0
    fi
    dir=$(dirname "$dir")
  done
  # Fall back to git's view (e.g. a project whose base repo is named otherwise).
  local common
  if common=$(git rev-parse --git-common-dir 2>/dev/null); then
    BASE=$(cd "$common" && pwd)
    PROJECT_DIR=$(dirname "$BASE")
    return 0
  fi
  die "not inside a wt project (no .base found). Use 'wt clone URL FOLDER' first."
}

default_branch() {
  # For a bare repo, HEAD points at the default branch.
  git -C "$BASE" symbolic-ref --short HEAD 2>/dev/null || printf 'main'
}

sanitize() { printf '%s' "$1" | tr '/:' '--'; }

project_name() { basename "$PROJECT_DIR"; }

# One tmux session per project; one window per worktree (branch).
project_session() { sanitize "$(project_name)"; }
window_name() { sanitize "$1"; }

# Print the worktree path for a branch, or nothing if it has no worktree.
worktree_path_for() {
  local target=$1 path="" branch=""
  while IFS= read -r line; do
    case "$line" in
      "worktree "*) path=${line#worktree } ;;
      "branch "*)   branch=${line#branch refs/heads/}
                    [ "$branch" = "$target" ] && { printf '%s' "$path"; return 0; } ;;
      "")           path=""; branch="" ;;
    esac
  done < <(git -C "$BASE" worktree list --porcelain 2>/dev/null)
  return 1
}

# ----------------------------------------------------------------------------
# tmux helpers
# ----------------------------------------------------------------------------
has_tmux() { command -v tmux >/dev/null 2>&1; }

session_exists() { tmux has-session -t "=$1" 2>/dev/null; }

# tmux has no has-window; check membership of the session's window list.
window_exists() {
  local session=$1 win=$2 w
  while IFS= read -r w; do
    [ "$w" = "$win" ] && return 0
  done < <(tmux list-windows -t "=$session" -F '#{window_name}' 2>/dev/null)
  return 1
}

apply_window_color() {
  local session=$1 win=$2 hex=$3 fg
  fg=$(fg_for_hex "$hex")
  # Referenced by window-status formats in tmux.conf (per-window user options).
  tmux set-window-option -t "$session:$win" @wt_bg "$hex" 2>/dev/null || true
  tmux set-window-option -t "$session:$win" @wt_fg "$fg" 2>/dev/null || true
  tmux set-window-option -t "$session:$win" pane-active-border-style "fg=$hex" 2>/dev/null || true
}

# Create the per-project session (detached) with a throwaway placeholder window.
ensure_project_session() {
  local session=$1
  session_exists "$session" && return 0
  tmux new-session -d -s "$session" -c "$PROJECT_DIR" -n __wt__
}

# Remove the placeholder window once at least one real worktree window exists.
kill_placeholder() {
  local session=$1
  window_exists "$session" __wt__ || return 0
  # Only kill it if there is another window to fall back to.
  local count
  count=$(tmux list-windows -t "=$session" 2>/dev/null | wc -l)
  [ "$count" -gt 1 ] && tmux kill-window -t "$session:__wt__" 2>/dev/null || true
}

# Build a worktree window: one pane per WT_TMUX_LAYOUT entry.
build_worktree_window() {
  local session=$1 win=$2 dir=$3 first=1 p pname pcmd
  local -a panes
  IFS=',' read -ra panes <<< "$WT_TMUX_LAYOUT"
  # Append after the last window. A bare "-t $session" target resolves to the
  # caller's *current* window when run from inside a client, and without -a/-b
  # tmux treats that as the literal index to create at -> "index N in use" when
  # invoked from an existing worktree window. -a -t "$session:{last}" sidesteps
  # this by always inserting after the final window (renumber-windows keeps it
  # gap-free), regardless of which window is current.
  tmux new-window -a -t "$session:{last}" -n "$win" -c "$dir"
  if [ "${#panes[@]}" -eq 0 ]; then
    return
  fi
  for p in "${panes[@]}"; do
    pname=${p%%=*}; pcmd=${p#*=}
    [ "$pname" = "$p" ] && pcmd=""
    # The first entry uses the window's initial pane; the rest are splits.
    if [ "$first" = 1 ]; then
      first=0
    else
      tmux split-window -t "$session:$win" -c "$dir"
    fi
    # send-keys targets the active pane, which is the one just created.
    [ -n "$pcmd" ] && tmux send-keys -t "$session:$win" "$pcmd" C-m
  done
  # even-horizontal lays panes left-to-right in WT_TMUX_LAYOUT order, so the
  # first entry (shell) is leftmost and claude sits on the right. tiled was
  # avoided because it picks top/bottom vs left/right based on the window's
  # aspect ratio, making the layout non-deterministic.
  tmux select-layout -t "$session:$win" even-horizontal 2>/dev/null || true
  # Focus the rightmost pane (claude) regardless of pane-base-index.
  tmux select-pane -t "$session:$win.{bottom-right}" 2>/dev/null \
    || tmux select-pane -t "$session:$win.{right}" 2>/dev/null || true
}

# Ensure a worktree window exists in the session, with its branch color applied.
ensure_worktree_window() {
  local session=$1 branch=$2 dir=$3 hex=$4 win
  win=$(window_name "$branch")
  if ! window_exists "$session" "$win"; then
    build_worktree_window "$session" "$win" "$dir"
  fi
  apply_window_color "$session" "$win" "$hex"
}

attach_or_switch() {
  local session=$1 win=${2:-}
  [ -n "$win" ] && tmux select-window -t "$session:$win" 2>/dev/null || true
  if [ -n "${TMUX:-}" ]; then
    tmux switch-client -t "$session"
  else
    tmux attach -t "$session"
  fi
}

# ----------------------------------------------------------------------------
# Editor theming
# ----------------------------------------------------------------------------
write_vscode_settings() {
  local dir=$1 hex=$2 fg cc f tmp
  fg=$(fg_for_hex "$hex")
  cc=$(cat <<JSON
{
  "titleBar.activeBackground": "$hex",
  "titleBar.activeForeground": "$fg",
  "titleBar.inactiveBackground": "$hex",
  "titleBar.inactiveForeground": "$fg",
  "activityBar.background": "$hex",
  "activityBar.foreground": "$fg"
}
JSON
)
  mkdir -p "$dir/.vscode"
  f="$dir/.vscode/settings.json"
  if command -v jq >/dev/null 2>&1; then
    local input='{}'
    [ -f "$f" ] && input=$(cat "$f")
    tmp=$(mktemp)
    if printf '%s' "$input" | jq --argjson cc "$cc" \
        '.["workbench.colorCustomizations"] = ((.["workbench.colorCustomizations"] // {}) + $cc)' \
        > "$tmp" 2>/dev/null; then
      mv "$tmp" "$f"
    else
      rm -f "$tmp"
      warn "could not merge $f (invalid JSON?); leaving it untouched."
      [ -f "$f" ] || printf '{\n  "workbench.colorCustomizations": %s\n}\n' "$cc" > "$f"
    fi
  elif [ -f "$f" ]; then
    warn "$f exists but jq is not installed; skipping color merge."
  else
    printf '{\n  "workbench.colorCustomizations": %s\n}\n' "$cc" > "$f"
  fi
}

# ----------------------------------------------------------------------------
# Per-worktree setup shared by clone/switch
# ----------------------------------------------------------------------------
setup_worktree() {
  local dir=$1 branch=$2 hex
  hex=$(color_for_branch "$branch")

  if [ -f "$dir/.gitmodules" ]; then
    info "Initializing submodules..."
    git -C "$dir" submodule update --init --recursive || warn "submodule init failed."
  fi

  # Copy configured untracked files from the default-branch worktree.
  local default src f
  default=$(default_branch)
  if src=$(worktree_path_for "$default") && [ "$src" != "$dir" ]; then
    local _ifs="$IFS"; IFS=':'
    for f in $WT_COPY; do
      [ -n "$f" ] || continue
      if [ -f "$src/$f" ] && [ ! -e "$dir/$f" ]; then
        mkdir -p "$dir/$(dirname "$f")"
        cp "$src/$f" "$dir/$f" && info "Copied $f from $default worktree."
      fi
    done
    IFS="$_ifs"
  fi

  write_vscode_settings "$dir" "$hex"
  # Keep our generated editor theme out of git status (worktree-local).
  add_local_exclude "$dir" "/.vscode/settings.json"
}

# Add a gitignore pattern to the repo-local exclude file (untracked paths only),
# so wt's own artifacts don't show up as dirty in `git status`.
add_local_exclude() {
  local dir=$1 pattern=$2 ex
  git -C "$dir" ls-files --error-unmatch "${pattern#/}" >/dev/null 2>&1 && return 0
  ex=$(git -C "$dir" rev-parse --git-path info/exclude 2>/dev/null) || return 0
  case "$ex" in /*) ;; *) ex="$dir/$ex" ;; esac
  mkdir -p "$(dirname "$ex")"
  grep -qxF "$pattern" "$ex" 2>/dev/null || printf '%s\n' "$pattern" >> "$ex"
}

# Ensure the project session + this worktree's window, then hand off the shell.
enter_worktree() {
  local dir=$1 branch=$2 hex session win
  hex=$(color_for_branch "$branch")
  session=$(project_session)
  win=$(window_name "$branch")
  emit_cd "$dir"
  has_tmux || { warn "tmux not installed; skipping session (cd only)."; return; }
  ensure_project_session "$session"
  ensure_worktree_window "$session" "$branch" "$dir" "$hex"
  kill_placeholder "$session"
  attach_or_switch "$session" "$win"
}

# ----------------------------------------------------------------------------
# Commands
# ----------------------------------------------------------------------------
cmd_clone() {
  local url=${1:-} folder=${2:-}
  [ -n "$url" ] || die "usage: wt clone GIT_URL [FOLDER]"
  if [ -z "$folder" ]; then
    folder=$(basename "$url"); folder=${folder%.git}
  fi

  local dest=$folder
  case "$dest" in /*) ;; *) dest="$CODE_HOME/$folder" ;; esac
  [ -e "$dest" ] && die "$dest already exists."

  info "Cloning $url -> $dest/.base"
  mkdir -p "$dest"
  git clone --bare "$url" "$dest/.base" || die "clone failed."
  git -C "$dest/.base" config remote.origin.fetch '+refs/heads/*:refs/remotes/origin/*'
  git -C "$dest/.base" fetch origin || warn "initial fetch failed."
  git -C "$dest/.base" remote set-head origin -a >/dev/null 2>&1 || true

  BASE="$dest/.base"; PROJECT_DIR="$dest"
  local branch dir
  branch=$(default_branch)
  dir="$PROJECT_DIR/$(sanitize "$branch")"
  info "Creating worktree for '$branch' at $dir"
  git -C "$BASE" worktree add "$dir" "$branch" || die "worktree add failed."

  setup_worktree "$dir" "$branch"
  enter_worktree "$dir" "$branch"
}

# Ensure a worktree exists for BRANCH, creating it off the latest default
# branch if needed. On success sets the global WT_RESULT_DIR to the resolved
# worktree directory; never touches tmux. Assumes resolve_base has run. We use
# a global rather than stdout so that `die` (which exits) still aborts the whole
# process instead of just a command-substitution subshell, and so callers like
# cmd_path keep stdout clean (info/warn already go to stderr).
WT_RESULT_DIR=""
ensure_worktree() {
  local branch=$1 default base_ref dir

  if dir=$(worktree_path_for "$branch"); then
    info "Using existing worktree: $dir"
    git -C "$dir" pull --ff-only >/dev/null 2>&1 \
      && info "Pulled latest." || warn "skipped pull (no upstream or not fast-forward)."
    WT_RESULT_DIR="$dir"
    return 0
  fi

  # New worktree.
  info "Fetching latest..."
  git -C "$BASE" fetch origin >/dev/null 2>&1 || warn "fetch failed; using local refs."

  default=$(default_branch)
  dir="$PROJECT_DIR/$(sanitize "$branch")"
  [ -e "$dir" ] && die "$dir already exists but is not a worktree for '$branch'."

  # Redirect git worktree add's chatter to stderr so cmd_path's stdout carries
  # only the resolved path (the resolver contract for remote tooling).
  if git -C "$BASE" show-ref --verify --quiet "refs/heads/$branch"; then
    info "Creating worktree for existing local branch '$branch' at $dir"
    git -C "$BASE" worktree add "$dir" "$branch" >&2 || die "worktree add failed."
  elif git -C "$BASE" show-ref --verify --quiet "refs/remotes/origin/$branch"; then
    info "Creating worktree tracking origin/$branch at $dir"
    git -C "$BASE" worktree add --track -b "$branch" "$dir" "origin/$branch" >&2 \
      || die "worktree add failed."
  else
    base_ref="$default"
    git -C "$BASE" show-ref --verify --quiet "refs/remotes/origin/$default" \
      && base_ref="origin/$default"
    info "Creating new branch '$branch' off $base_ref at $dir"
    git -C "$BASE" worktree add -b "$branch" "$dir" "$base_ref" >&2 || die "worktree add failed."
  fi

  setup_worktree "$dir" "$branch"
  WT_RESULT_DIR="$dir"
}

cmd_switch() {
  resolve_base
  local branch=${1:-}
  # Tolerate a trailing slash from directory tab-completion (e.g. "feat/").
  while [ "${branch%/}" != "$branch" ]; do branch=${branch%/}; done

  if [ -z "$branch" ]; then
    if command -v fzf >/dev/null 2>&1; then
      branch=$(git -C "$BASE" worktree list --porcelain \
        | awk '/^branch /{sub("branch refs/heads/",""); print}' \
        | fzf --prompt="worktree> " --height=40% --reverse) || return 0
      [ -n "$branch" ] || return 0
    else
      die "usage: wt BRANCH   (install fzf for an interactive picker)"
    fi
  fi

  ensure_worktree "$branch"
  enter_worktree "$WT_RESULT_DIR" "$branch"
}

# Resolve (creating if needed) BRANCH's worktree and print its path to stdout.
# Headless counterpart to cmd_switch for remote tooling driving wt over SSH:
#   ssh HOST "bash -lc 'cd ~/Code/PROJECT && wt path BRANCH'"
# stdout carries only the path; all status/log output goes to stderr.
cmd_path() {
  resolve_base
  local branch=${1:-}
  while [ "${branch%/}" != "$branch" ]; do branch=${branch%/}; done
  [ -n "$branch" ] || die "usage: wt path BRANCH"
  ensure_worktree "$branch"
  printf '%s\n' "$WT_RESULT_DIR"
}

cmd_tmux() {
  resolve_base
  has_tmux || die "tmux is not installed."
  local session; session=$(project_session)
  ensure_project_session "$session"

  # Build a window for every existing worktree (skip the bare repo entry).
  local path="" branch="" bare=0 default hex
  default=$(default_branch)
  while IFS= read -r line; do
    case "$line" in
      "worktree "*) path=${line#worktree } ;;
      "branch "*)   branch=${line#branch refs/heads/} ;;
      "bare")       bare=1 ;;
      "")
        if [ -n "$path" ] && [ -n "$branch" ] && [ "$bare" -eq 0 ]; then
          hex=$(color_for_branch "$branch")
          ensure_worktree_window "$session" "$branch" "$path" "$hex"
        fi
        path=""; branch=""; bare=0 ;;
    esac
  done < <(git -C "$BASE" worktree list --porcelain 2>/dev/null)
  if [ -n "$path" ] && [ -n "$branch" ] && [ "$bare" -eq 0 ]; then
    hex=$(color_for_branch "$branch")
    ensure_worktree_window "$session" "$branch" "$path" "$hex"
  fi

  kill_placeholder "$session"
  attach_or_switch "$session" "$(window_name "$default")"
}

cmd_list() {
  resolve_base
  if [ "${1:-}" = "--porcelain" ]; then
    _list_porcelain
    return
  fi
  local path="" branch="" head="" bare=0
  printf '%bProject:%b %s  %b(%s)%b\n' \
    "$_c_bold" "$_c_reset" "$(project_name)" "$_c_dim" "$PROJECT_DIR" "$_c_reset" >&2
  while IFS= read -r line; do
    case "$line" in
      "worktree "*) path=${line#worktree } ;;
      "HEAD "*)     head=${line#HEAD } ;;
      "branch "*)   branch=${line#branch refs/heads/} ;;
      "detached")   branch="(detached)" ;;
      "bare")       bare=1 ;;
      "")
        [ -n "$path" ] && [ "$bare" -eq 0 ] && _print_worktree_row "$path" "$branch" "$head"
        path=""; branch=""; head=""; bare=0 ;;
    esac
  done < <(git -C "$BASE" worktree list --porcelain 2>/dev/null)
  [ -n "$path" ] && [ "$bare" -eq 0 ] && _print_worktree_row "$path" "$branch" "$head"
}

# Machine-readable enumerator for remote tooling: one "branch<TAB>path" line per
# worktree on stdout (skips the bare repo and detached/no-branch entries), with
# no swatches, tmux/dirty status, or project header.
_list_porcelain() {
  local path="" branch="" bare=0
  while IFS= read -r line; do
    case "$line" in
      "worktree "*) path=${line#worktree } ;;
      "branch "*)   branch=${line#branch refs/heads/} ;;
      "bare")       bare=1 ;;
      "")
        [ -n "$path" ] && [ -n "$branch" ] && [ "$bare" -eq 0 ] \
          && printf '%s\t%s\n' "$branch" "$path"
        path=""; branch=""; bare=0 ;;
    esac
  done < <(git -C "$BASE" worktree list --porcelain 2>/dev/null)
  [ -n "$path" ] && [ -n "$branch" ] && [ "$bare" -eq 0 ] \
    && printf '%s\t%s\n' "$branch" "$path"
  # Always succeed: the trailing guard above is false when the last entry was
  # already flushed by a porcelain blank line, which would otherwise leak a
  # non-zero exit status to machine callers using `set -e`.
  return 0
}

_print_worktree_row() {
  local path=$1 branch=$2 head=$3 hex sw tmux_mark dirty=" "
  [ -n "$branch" ] || branch="(no branch)"
  hex=$(color_for_branch "$branch")
  sw=$(swatch "$hex")
  if window_exists "$(project_session)" "$(window_name "$branch")" 2>/dev/null; then
    tmux_mark="${_c_green}tmux${_c_reset}"
  else
    tmux_mark="${_c_dim} -- ${_c_reset}"
  fi
  if [ -d "$path" ] && [ -n "$(git -C "$path" status --porcelain 2>/dev/null)" ]; then
    dirty="${_c_yellow}*${_c_reset}"
  fi
  printf '%b  %b  %b %-26s %b%s%b\n' \
    "$sw" "$tmux_mark" "$dirty" "$branch" "$_c_dim" "$path" "$_c_reset" >&2
}

cmd_prune() {
  resolve_base
  local default; default=$(default_branch)
  info "Fetching and pruning remotes..."
  git -C "$BASE" fetch --prune origin >/dev/null 2>&1 || warn "fetch failed; using local state."

  local -a candidates=()
  local path="" branch=""
  while IFS= read -r line; do
    case "$line" in
      "worktree "*) path=${line#worktree } ;;
      "branch "*)   branch=${line#branch refs/heads/} ;;
      "")
        _prune_consider "$path" "$branch" && candidates+=("$branch"$'\t'"$path")
        path=""; branch="" ;;
    esac
  done < <(git -C "$BASE" worktree list --porcelain 2>/dev/null)
  _prune_consider "$path" "$branch" && candidates+=("$branch"$'\t'"$path")

  if [ "${#candidates[@]}" -eq 0 ]; then
    info "Nothing to prune."
    return
  fi

  log "The following worktrees are merged or gone (branch refs are kept):"
  local entry b p
  for entry in "${candidates[@]}"; do
    b=${entry%%$'\t'*}; p=${entry#*$'\t'}
    printf '  %b %-28s %b%s%b\n' "$(swatch "$(color_for_branch "$b")")" "$b" "$_c_dim" "$p" "$_c_reset" >&2
  done
  printf 'Remove these worktree directories? [y/N] ' >&2
  local reply; read -r reply || reply=""
  case "$reply" in [yY]*) ;; *) info "Aborted."; return ;; esac

  for entry in "${candidates[@]}"; do
    b=${entry%%$'\t'*}; p=${entry#*$'\t'}
    has_tmux && tmux kill-window -t "$(project_session):$(window_name "$b")" 2>/dev/null || true
    if git -C "$BASE" worktree remove "$p" 2>/dev/null; then
      info "Removed worktree $p (branch '$b' kept)."
    else
      warn "$p is dirty; use 'wt rm $b --force' to remove it."
    fi
  done
  git -C "$BASE" worktree prune
}

# Returns 0 if the worktree is a prune candidate.
_prune_consider() {
  local path=$1 branch=$2 default
  [ -n "$path" ] && [ -n "$branch" ] || return 1
  default=$(default_branch)
  [ "$branch" = "$default" ] && return 1
  # Never prune the worktree we're currently inside.
  [ "$path" = "$PWD" ] && return 1
  # Merged into the default branch? (git marks worktree branches with '+',
  # the current branch with '*'; take the last field to ignore those.)
  if git -C "$BASE" branch --merged "origin/$default" 2>/dev/null \
       | awk '{print $NF}' | grep -qx "$branch"; then
    return 0
  fi
  # Upstream gone (was tracking a remote branch that no longer exists)?
  if git -C "$BASE" rev-parse --verify --quiet "$branch@{upstream}" >/dev/null 2>&1; then
    return 1
  fi
  if git -C "$BASE" config --get "branch.$branch.remote" >/dev/null 2>&1; then
    return 0
  fi
  return 1
}

cmd_rm() {
  resolve_base
  local branch=${1:-} force=${2:-}
  [ -n "$branch" ] || die "usage: wt rm BRANCH [--force]"
  local dir
  dir=$(worktree_path_for "$branch") || die "no worktree for branch '$branch'."
  has_tmux && tmux kill-window -t "$(project_session):$(window_name "$branch")" 2>/dev/null || true
  if [ "$force" = "--force" ] || [ "$force" = "-f" ]; then
    git -C "$BASE" worktree remove --force "$dir"
  else
    git -C "$BASE" worktree remove "$dir" \
      || die "$dir has changes; re-run with --force to discard them."
  fi
  info "Removed worktree for '$branch' (branch ref kept)."
}

cmd_color() {
  local branch=${1:-}
  [ -n "$branch" ] || die "usage: wt color BRANCH"
  local hex; hex=$(color_for_branch "$branch")
  printf '%b %s\n' "$(swatch "$hex")" "$hex"
}

usage() {
  cat >&2 <<'EOF'
wt - worktree-centric session manager

Usage:
  wt clone GIT_URL [FOLDER]   Clone a repo as a bare .base + default worktree
  wt BRANCH                   Switch to (or create) a worktree for BRANCH
  wt switch [BRANCH]          Same as above; no BRANCH opens an fzf picker
  wt path BRANCH              Resolve (creating if needed) BRANCH's worktree; print its path
  wt tmux                     Attach the project session, building a window per worktree
  wt list | ls [--porcelain]  List worktrees; --porcelain prints branch<TAB>path to stdout
  wt prune                    Remove merged/gone worktrees (keeps branch refs)
  wt rm BRANCH [--force]      Remove a single worktree (keeps branch ref)
  wt color BRANCH             Print the deterministic color for BRANCH
  wt help                     Show this help

Sessions: one tmux session per project, one window per worktree, and one pane
per WT_TMUX_LAYOUT entry split within that window.

Environment:
  CODE_HOME         Base dir for new projects (default: ~/Code)
  WT_TMUX_LAYOUT    tmux panes as name=cmd,name=cmd (default: shell=,claude=claude)
  WT_COPY           Colon-separated untracked files to copy into new worktrees (default: .env)
EOF
}

# ----------------------------------------------------------------------------
# Dispatch
# ----------------------------------------------------------------------------
main() {
  local cmd=${1:-}
  case "$cmd" in
    clone)            shift; cmd_clone "$@" ;;
    switch|sw)        shift; cmd_switch "$@" ;;
    path)             shift; cmd_path "$@" ;;
    tmux)             shift; cmd_tmux "$@" ;;
    list|ls)          shift; cmd_list "$@" ;;
    prune)            shift; cmd_prune "$@" ;;
    rm|remove)        shift; cmd_rm "$@" ;;
    color)            shift; cmd_color "$@" ;;
    help|-h|--help)   usage ;;
    "")               cmd_switch ;;
    *)                cmd_switch "$cmd" ;;
  esac
}

main "$@"
